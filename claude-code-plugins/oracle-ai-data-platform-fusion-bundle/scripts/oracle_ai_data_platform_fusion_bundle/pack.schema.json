      "properties": {
        "columnExists": {
          "title": "Columnexists",
          "type": "string"
        }
      },
      "required": [
        "columnExists"
      ],
      "title": "SemanticVariantDetect",
      "type": "object"
    },
    "SkillProposalRecord": {
      "additionalProperties": false,
