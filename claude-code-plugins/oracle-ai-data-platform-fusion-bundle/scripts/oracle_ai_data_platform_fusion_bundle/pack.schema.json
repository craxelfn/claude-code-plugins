{
  "$defs": {
    "CalendarProfile": {
      "additionalProperties": false,
      "description": "Default calendar dimensions for the dim_calendar builtin (ADR-0011).",
      "properties": {
        "endDate": {
          "title": "Enddate",
          "type": "string"
        },
        "fiscalStartMonth": {
          "default": 1,
          "maximum": 12,
          "minimum": 1,
          "title": "Fiscalstartmonth",
          "type": "integer"
        },
        "startDate": {
          "title": "Startdate",
          "type": "string"
        }
      },
      "required": [
        "startDate",
        "endDate"
      ],
      "title": "CalendarProfile",
      "type": "object"
    },
    "ChartOfAccountsProfile": {
      "additionalProperties": false,
      "description": "COA segment role->column mapping for a tenant.\n\nTwo shapes are accepted:\n\n* **Flat / legacy** -- ``balancingSegment`` / ``costCenterSegment`` /\n  ``naturalAccountSegment`` directly on this object (the pre-feature pack\n  default shape, kept back-compat-parseable).\n* **Nested** -- ``default`` (a :class:`CoaRoleMapping`) plus optional\n  per-chart ``byChart`` arms keyed by ``CodeCombinationChartOfAccountsId``\n  (the multi-COA serving shape).\n\nThe flat and nested ``default`` shapes are mutually exclusive (declaring\nboth is an error). Use :meth:`resolved_default` to read the effective\ndefault regardless of which shape was authored.",
      "properties": {
        "balancingSegment": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Balancingsegment"
        },
        "byChart": {
          "anyOf": [
            {
              "additionalProperties": {
                "$ref": "#/$defs/CoaRoleMapping"
              },
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Bychart"
        },
        "costCenterSegment": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Costcentersegment"
        },
        "default": {
          "anyOf": [
            {
              "$ref": "#/$defs/CoaRoleMapping"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "naturalAccountSegment": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Naturalaccountsegment"
        },
        "singletonAccepted": {
          "default": false,
          "title": "Singletonaccepted",
          "type": "boolean"
        }
      },
      "title": "ChartOfAccountsProfile",
      "type": "object"
    },
    "CoaRoleMapping": {
      "additionalProperties": false,
      "description": "One chart's COA role -> physical-column-name binding.\n\nValues are physical column names (e.g. ``CodeCombinationSegment4``), not\ninteger positions -- so the binding survives non-conventional column\nnaming and can be existence-validated against the bronze contract.",
      "properties": {
        "balancingSegment": {
          "title": "Balancingsegment",
          "type": "string"
        },
        "costCenterSegment": {
          "title": "Costcentersegment",
          "type": "string"
        },
        "naturalAccountSegment": {
          "title": "Naturalaccountsegment",
          "type": "string"
        }
      },
      "required": [
        "balancingSegment",
        "costCenterSegment",
        "naturalAccountSegment"
      ],
      "title": "CoaRoleMapping",
      "type": "object"
    },
    "ColumnAlias": {
      "additionalProperties": false,
      "description": "Same logical column, different physical names across tenants.\n\nBootstrap walks ``candidates`` in priority order and pins the first that\nexists on the tenant.",
      "properties": {
        "appliesTo": {
          "title": "Appliesto",
          "type": "string"
        },
        "candidates": {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "title": "Candidates",
          "type": "array"
        },
        "required": {
          "default": true,
          "title": "Required",
          "type": "boolean"
        },
        "resolution": {
          "default": "columnExistence",
          "enum": [
            "columnExistence",
            "semanticRole"
          ],
          "title": "Resolution",
          "type": "string"
        },
        "role": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Role"
        }
      },
      "required": [
        "appliesTo",
        "candidates"
      ],
      "title": "ColumnAlias",
      "type": "object"
    },
    "ForkedFrom": {
      "additionalProperties": false,
      "description": "Provenance fingerprints a ``replaceNode`` overlay was forked from.\n\nA same-id silver/gold full replacement *shadows* the base ``<id>.sql`` and\nthe base node YAML contract; silver/gold have no drift gate against the base,\nso a later starter-pack fix to the base mart would be silently missed. These\nfingerprints, recomputed at ``content-pack validate``, convert that *silent*\nstaleness into a *loud* one (``AIDPF-2047``):\n\n* ``sql_sha256`` \u2014 the base SQL template text + the referenced\n  ``{{ semantic.* }}`` candidate lists (pack-owned render inputs).\n* ``contract_sha256`` \u2014 the base node YAML contract (``outputSchema`` incl.\n  ``pii``, ``requiredColumns``, ``quality.tests``). A base change that touches\n  only the YAML (e.g. a PII reclassification) trips ``AIDPF-2047`` too.\n* ``pack_version`` \u2014 the base pack version at fork time (recorded provenance).\n\nBoth fingerprints are profile-independent and validate-time computable. Keys\nare camelCase in YAML (``sqlSha256`` / ``contractSha256`` / ``packVersion``),\nmatching ``outputSchema`` / ``requiredColumns``.",
      "properties": {
        "contractSha256": {
          "minLength": 1,
          "title": "Contractsha256",
          "type": "string"
        },
        "packVersion": {
          "minLength": 1,
          "title": "Packversion",
          "type": "string"
        },
        "sqlSha256": {
          "minLength": 1,
          "title": "Sqlsha256",
          "type": "string"
        }
      },
      "required": [
        "sqlSha256",
        "contractSha256",
        "packVersion"
      ],
      "title": "ForkedFrom",
      "type": "object"
    },
    "IncrementalImpact": {
      "additionalProperties": false,
      "description": "Per-VP impact analysis recorded on both the overlay and the\nevidence snapshot.\n\nThe medallion-author skill populates this when drafting an overlay;\nbootstrap mirrors it into the per-resolution evidence on the\n``--refresh`` commit and on initial commit when the overlay is\nskill-authored.",
      "properties": {
        "affectedNodes": {
          "items": {
            "type": "string"
          },
          "title": "Affectednodes",
          "type": "array"
        },
        "changeKind": {
          "enum": [
            "initial",
            "promotion",
            "demotion"
          ],
          "title": "Changekind",
          "type": "string"
        },
        "newCandidate": {
          "title": "Newcandidate",
          "type": "string"
        },
        "priorPinned": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Priorpinned"
        },
        "remediation": {
          "$ref": "#/$defs/RemediationRecord"
        },
        "riskLabel": {
          "enum": [
            "likely-rename",
            "likely-different-semantics",
            "unknown"
          ],
          "title": "Risklabel",
          "type": "string"
        }
      },
      "required": [
        "changeKind",
        "newCandidate",
        "riskLabel",
        "remediation"
      ],
      "title": "IncrementalImpact",
      "type": "object"
    },
    "OutputSchemaColumnOverride": {
      "additionalProperties": false,
      "description": "One column entry in an overlay's ``outputSchema`` override.\n\nDistinct from :class:`OutputSchemaColumn`: ``name`` is the merge key and is\nrequired, while ``type``/``nullable``/``pii`` are **optional** so a *matched*\n(retype) column may override only the fields it changes and inherit the rest\nfrom the base column. A *matched* column must still set at least one mutable\nfield (a name-only entry is a no-op and is rejected). Appended columns (a name\nabsent from the base) must carry full ``type`` + ``pii`` \u2014 enforced in the\nmerge step, where base-vs-overlay membership is known.",
      "properties": {
        "name": {
          "title": "Name",
          "type": "string"
        },
        "nullable": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Nullable"
        },
        "pii": {
          "anyOf": [
            {
              "enum": [
                "high",
                "medium",
                "low",
                "none"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Pii"
        },
        "type": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Type"
        }
      },
      "required": [
        "name"
      ],
      "title": "OutputSchemaColumnOverride",
      "type": "object"
    },
    "OutputSchemaOverride": {
      "additionalProperties": false,
      "description": "An overlay's ``outputSchema`` override: a name-keyed, partial merge into\nthe base node's columns.\n\nDeclare only the columns you change. Matched columns are retyped; with\n``extendColumns: true`` a new column may be appended (full ``type`` + ``pii``\nrequired, enforced at merge). Base columns not listed are preserved.",
      "properties": {
        "columns": {
          "items": {
            "$ref": "#/$defs/OutputSchemaColumnOverride"
          },
          "minItems": 1,
          "title": "Columns",
          "type": "array"
        },
        "extendColumns": {
          "default": false,
          "title": "Extendcolumns",
          "type": "boolean"
        }
      },
      "required": [
        "columns"
      ],
      "title": "OutputSchemaOverride",
      "type": "object"
    },
    "OverrideEntry": {
      "additionalProperties": false,
      "description": "Per-node override declared by an overlay pack.\n\nMerge rules:\n\n* ``profile:`` -- scalar replace.\n* ``sql:`` -- full-file replace; the named SQL path lives in the overlay.\n* ``quality:`` -- nested ``tests:`` list extends base.\n* ``outputSchema:`` -- name-keyed partial merge of a bronze node's\n  output columns (retype matched columns; append with ``extendColumns``).\n  Bronze targets only; enforced at merge.\n* ``requiredColumns:`` -- additive per-source union into a bronze node's\n  required columns (adds only; never removes). Bronze targets only.\n* ``relaxRequiredColumns:`` -- acknowledged per-source REMOVAL of a bronze\n  node's required columns (each entry carries a mandatory ``reason``).\n  Bronze targets only; this is the *only* sanctioned removal path.\n* ``replaceNode:`` -- acknowledged same-id silver/gold full replacement\n  (`.yaml` + `.sql`). Silver/gold targets only; mutually exclusive with every\n  other key (the replacement files carry the new schema/SQL). See\n  :class:`ReplaceNode`.\n\nUnknown keys fail closed (``extra=\"forbid\"``) with an actionable\nAIDPF-2001 message.",
      "properties": {
        "outputSchema": {
          "anyOf": [
            {
              "$ref": "#/$defs/OutputSchemaOverride"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "profile": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Profile"
        },
        "quality": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Quality"
        },
        "relaxRequiredColumns": {
          "anyOf": [
            {
              "additionalProperties": {
                "items": {
                  "$ref": "#/$defs/RelaxRequiredColumn"
                },
                "type": "array"
              },
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Relaxrequiredcolumns"
        },
        "replaceNode": {
          "anyOf": [
            {
              "$ref": "#/$defs/ReplaceNode"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "requiredColumns": {
          "anyOf": [
            {
              "additionalProperties": {
                "items": {
                  "type": "string"
                },
                "type": "array"
              },
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Requiredcolumns"
        },
        "sql": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Sql"
        }
      },
      "title": "OverrideEntry",
      "type": "object"
    },
    "PackCompatibility": {
      "additionalProperties": false,
