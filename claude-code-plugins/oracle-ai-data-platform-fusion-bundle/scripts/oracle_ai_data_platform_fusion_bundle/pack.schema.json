            {
              "type": "null"
            }
          ],
          "default": null
        },
        "chartOfAccounts": {
          "anyOf": [
            {
              "$ref": "#/$defs/ChartOfAccountsProfile"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "title": "PackProfileDefaults",
      "type": "object"
    },
    "PackProvenance": {
