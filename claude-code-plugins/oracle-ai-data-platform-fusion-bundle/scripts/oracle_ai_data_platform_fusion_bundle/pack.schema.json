            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Generatedat"
        },
        "generatedBy": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Generatedby"
        },
        "incrementalImpact": {
          "anyOf": [
            {
              "additionalProperties": {
                "$ref": "#/$defs/IncrementalImpact"
              },
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Incrementalimpact"
        },
        "modelId": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Modelid"
        },
        "operatorInputId": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Operatorinputid"
        },
        "proposals": {
          "anyOf": [
            {
              "additionalProperties": {
                "$ref": "#/$defs/SkillProposalRecord"
              },
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Proposals"
        },
        "reason": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Reason"
        },
        "skillId": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Skillid"
        },
        "skillVersion": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Skillversion"
        },
        "trigger": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Trigger"
        }
      },
      "title": "PackProvenance",
      "type": "object"
    },
    "RelaxRequiredColumn": {
      "additionalProperties": false,
      "description": "One acknowledged removal of a bronze node's ``requiredColumns`` entry.\n\nRemoving a required column *weakens* a live safety gate (the per-node\npreflight assertion + PVO-drift watch stop covering it), so it is allowed\nonly behind an explicit, audited acknowledgement: the ``reason`` is\nmandatory and must be non-blank \u2014 it is the *only* control on the\ngate-weakening op. A missing key, ``\"\"``, or whitespace-only string all fail\nclosed (a bare ``min_length`` would accept ``\"   \"``).",
      "properties": {
        "column": {
          "minLength": 1,
          "title": "Column",
          "type": "string"
        },
        "reason": {
          "minLength": 1,
          "title": "Reason",
          "type": "string"
        }
      },
      "required": [
        "column",
        "reason"
      ],
      "title": "RelaxRequiredColumn",
      "type": "object"
    },
    "RemediationRecord": {
      "additionalProperties": false,
      "description": "The remediation choice recorded for one variation-point change.",
      "properties": {
        "operatorChose": {
          "enum": [
            "A",
            "B",
            "C",
            "D",
            "E"
          ],
          "title": "Operatorchose",
          "type": "string"
        },
        "rationale": {
          "title": "Rationale",
          "type": "string"
        },
        "recommended": {
          "enum": [
            "A",
            "B",
            "C",
            "D",
            "E"
          ],
          "title": "Recommended",
          "type": "string"
        }
      },
      "required": [
        "recommended",
        "operatorChose",
        "rationale"
      ],
      "title": "RemediationRecord",
      "type": "object"
    },
    "ReplaceNode": {
      "additionalProperties": false,
      "description": "Acknowledged same-id silver/gold full replacement (`.yaml` + `.sql`).\n\nSame-id silver/gold replacement is rejected by default (``AIDPF-2001``); a\n``replaceNode`` block makes it legal \u2014 opt-in and audited, mirroring the\n``relaxRequiredColumns`` precedent. The overlay ships a complete new\n``<layer>/<id>.yaml`` + ``<id>.sql`` for a shipped SQL mart, keeping its id so\ndownstream ``dependsOn`` consumers are not re-pointed. Add, remove, and\nrewrite of columns/logic all go through this one shape; only identity changes\n(``layer`` / ``target`` / ``dependsOn`` edges / ``refresh``) remain new-mart-id.",
      "properties": {
        "forkedFrom": {
          "$ref": "#/$defs/ForkedFrom"
        },
        "reason": {
          "minLength": 1,
          "title": "Reason",
          "type": "string"
        }
      },
      "required": [
        "reason",
        "forkedFrom"
      ],
      "title": "ReplaceNode",
      "type": "object"
    },
    "RunIdColumnDefaults": {
      "additionalProperties": false,
      "description": "Audit column names per medallion layer.",
      "properties": {
        "bronze": {
          "default": "_run_id",
          "title": "Bronze",
          "type": "string"
        },
        "gold": {
          "default": "gold_run_id",
